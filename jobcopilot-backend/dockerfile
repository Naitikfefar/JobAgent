FROM node:22

RUN apt-get update && \
    apt-get install -y python3 python3-pip && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package*.json ./

RUN npm ci

COPY . .

RUN pip3 install --break-system-packages \
    requests \
    beautifulsoup4 \
    reportlab \
    pdfplumber

EXPOSE 5000

CMD ["node", "server.js"]